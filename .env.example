SECRET_KEY=
DEBUG=True

# Credentials: Override if not using defaults
DB_NAME=jobplatform
DB_USER=jobplatform
DB_PASSWORD=jobplatform
MINIO_USER=jobplatform
MINIO_PASSWORD=jobplatform
MINIO_BUCKET=jobplatform

# MinIO: Public endpoint for files served to users
MINIO_PUBLIC_ENDPOINT=localhost:9000

# Livekit credentials
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AI Settings
# AI Backend: "local" for local AI, "groq" for production
# AI_GPU_VENDOR: "nvidia", "amd" or "cpu"
AI_BACKEND=groq
AI_GPU_VENDOR=cpu

# AI Model: AMD/CPU users should pick a .gguf model, Nvidia users should pick an ollama model
AI_LOCAL_MODEL=qwen2.5-3b-instruct-q4_k_m.gguf
AI_GROQ_MODEL=llama-3.3-70b-versatile

# Groq API key (only when using AI_BACKEND=groq)
GROQ_API_KEY=
