SECRET_KEY=
DEBUG=True

# Credentials: Override if not using defaults
DB_NAME=jobplatform
DB_USER=jobplatform
DB_PASSWORD=jobplatform
MINIO_USER=jobplatform
MINIO_PASSWORD=jobplatform
MINIO_BUCKET=jobplatform

# MinIO: Public endpoint for files served to users
MINIO_PUBLIC_ENDPOINT=localhost:9000

# Livekit credentials
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AI Backend — "llama" for local dev, "groq" for production
AI_BACKEND=groq

# Local llama.cpp (dev only)
# Place your .gguf model in ./models/ before starting
# Profiles: nvidia | amd | cpu
LLAMA_MODEL=qwen2.5-3b-instruct-q4_k_m.gguf
LLAMA_HOST=http://llama-cpp-nvidia:8080  # or llama-cpp-amd / llama-cpp-cpu

# Groq (production)
GROQ_API_KEY=your_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
