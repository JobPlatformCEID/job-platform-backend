SECRET_KEY=
DEBUG=True

# Credentials: Override if not using defaults
DB_NAME=jobplatform
DB_USER=jobplatform
DB_PASSWORD=jobplatform
MINIO_USER=jobplatform
MINIO_PASSWORD=jobplatform
MINIO_BUCKET=jobplatform

# MinIO: Public endpoint for files served to users
MINIO_PUBLIC_ENDPOINT=localhost:9000

# LiveKit Settings (self-hosted, localhost testing)
LIVEKIT_API_KEY=livekitdev
LIVEKIT_API_SECRET=livekitdevsecret1234567890abcdef
LIVEKIT_KEYS=livekitdev: livekitdevsecret1234567890abcdef

# Optional: URLs for Django/frontend
LIVEKIT_URL=ws://livekit:7880        # Backend (Docker network)
LIVEKIT_PUBLIC_URL=ws://localhost:7880  # Frontend (browser)
