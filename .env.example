SECRET_KEY=
DEBUG=True

# Credentials: Override if not using defaults
DB_NAME=jobplatform
DB_USER=jobplatform
DB_PASSWORD=jobplatform
MINIO_USER=jobplatform
MINIO_PASSWORD=jobplatform
MINIO_BUCKET=jobplatform

# MinIO: Public endpoint for files served to users
MINIO_PUBLIC_ENDPOINT=localhost:9000

# Livekit credentials
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AI Backend — "llama" for local dev, "groq" for production
AI_BACKEND=groq

# Ollama (nvidia local dev)
OLLAMA_HOST=http://ollama-nvidia:11434
OLLAMA_MODEL=qwen2.5:3b

# Llama.cpp (amd local dev) place your model in a /model dir
LLAMA_MODEL=qwen2.5-3b-instruct-q4_k_m.gguf
LLAMA_HOST=http://llama-cpp-amd:8080

#groq api
GROQ_API_KEY=your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
#GROQ_MODEL=llama-3.1-8b-instant # for testing
